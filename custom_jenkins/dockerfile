# Use official Jenkins LTS (Debian-based)
FROM jenkins/jenkins:lts

# Become root to install packages
USER root

# Install Docker CLI the modern way (keyring; no apt-key, no obsolete packages)
RUN apt-get update -y && \
    apt-get install -y --no-install-recommends ca-certificates curl gnupg lsb-release && \
    install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg && \
    chmod a+r /etc/apt/keyrings/docker.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
https://download.docker.com/linux/debian $(. /etc/os-release; echo $VERSION_CODENAME) stable" \
      | tee /etc/apt/sources.list.d/docker.list > /dev/null && \
    apt-get update -y && \
    # Install only the Docker CLI; the engine will be on the host
    apt-get install -y --no-install-recommends docker-ce-cli && \
    # (Optional) Compose plugin
    apt-get install -y --no-install-recommends docker-compose-plugin || true && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Allow jenkins user to talk to the Docker socket
RUN groupadd -f docker && usermod -aG docker jenkins

# Back to jenkins user
USER jenkins